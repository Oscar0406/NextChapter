# NextChapter Malaysia - server-side FreeLLMAPI configuration
# Copy this file to .env.local and fill FREELLMAPI_API_KEY before running generation.

# FreeLLMAPI is an OpenAI-compatible local/self-hosted proxy.
# Get this unified key from the FreeLLMAPI dashboard after adding upstream provider keys there.
FREELLMAPI_API_KEY=

# Defaults match the FreeLLMAPI Docker/server quick start.
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_MODEL=auto

# Gemini Google Search grounding through FreeLLMAPI.
# auto = use only when the profile needs fresh/relevant web context.
# always = always run Gemini Google Search grounding before pathway generation.
# disabled = curated Malaysia dataset only.
WEB_SEARCH_MODE=auto
FREELLMAPI_GEMINI_SEARCH_MODEL=gemini-2.5-flash

# Shared Supabase cache for public web grounding results.
# enabled = reuse strict intent-matched cache before Gemini search.
# disabled = skip cache and use the current web-search behavior.
WEB_GROUNDING_CACHE_MODE=enabled
WEB_GROUNDING_CACHE_TTL_DAYS=7
WEB_GROUNDING_CACHE_MIN_SCORE=0.55

# Optional request timeout for LLM calls. Defaults to 45000.
LLM_TIMEOUT_MS=45000

# Optional budgeting note for the team; not read by the app yet.
MONTHLY_TOKEN_BUDGET_RM=

# Supabase history storage.
# Create a pathway_history table with:
# id, session_id, current_condition, dream, pathways, title, created_at.
# Extra AI metadata is stored inside pathways JSONB.
SUPABASE_URL=
# Use the server-side service_role secret key, not the public anon key.
# This value must never be exposed with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
